{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd \"$(git rev-parse --show-toplevel)\" && corepack enable && pnpm install",
  "buildCommand": "node \"$(git rev-parse --show-toplevel)/scripts/build-vercel.mjs\"",
  "outputDirectory": "../heatmap/dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-refresh",
      "schedule": "0 0 * * *"
    }
  ]
}
