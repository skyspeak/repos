# --- Local development only (Vercel uses dashboard env vars) ---

# Database — use Neon, Supabase, or Vercel Postgres (pooled connection string)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Local API port
PORT=5080

# --- LLM API Keys (required on Vercel) ---

# OpenRouter — heatmap AI deep dives
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Google Gemini (free tier) — investment/S-1 analysis pipeline
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Provider routing (optional)
# INVESTMENT_LLM_PROVIDER=gemini
# DEEP_DIVE_LLM_PROVIDER=openrouter

# Vercel Cron — secures /api/cron/daily-refresh (set in Vercel dashboard)
# CRON_SECRET=your-random-secret
